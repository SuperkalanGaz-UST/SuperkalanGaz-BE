# App
PORT=3001
# Comma-separated list of allowed web-dashboard origins (CORS).
WEB_ORIGIN=http://localhost:3000

# Database — Supabase used as managed Postgres ONLY (standard connection + TypeORM).
# Do NOT use the Supabase client SDK or PostgREST (bypasses the branch-scoped JWT guards).
# Dashboard → Connect → Direct connection / Session pooler, e.g.:
#   postgresql://postgres:[PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# Supabase Auth — used to VERIFY caller JWTs (via the project's JWKS endpoint)
# and to administer identities through the GoTrue Admin REST API.
SUPABASE_URL=
# service_role key (Dashboard → Project Settings → API). Server-only secret.
SUPABASE_SERVICE_ROLE_KEY=
# Only needed for legacy projects that still sign JWTs with the shared HS256
# secret. Leave empty to verify against the JWKS endpoint (asymmetric keys).
SUPABASE_JWT_SECRET=
